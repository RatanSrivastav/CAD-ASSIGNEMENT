class Node:
    def __init__(self, key):
        self.left = None
        self.right = None
        self.val = key


def insert(root, key):
    if root is None:
        return Node(key)

    if key < root.val:
        root.left = insert(root.left, key)
    else:
        root.right = insert(root.right, key)

    return root


def inorder(root):
    if root:
        inorder(root.left)
        print(root.val, end=" ")
        inorder(root.right)


# Example
root = None
keys = [50, 30, 70, 20, 40, 60, 80]

for key in keys:
    root = insert(root, key)

print("Inorder Traversal:")
inorder(root)
